# RaPiSys configuration — deploy.sh generates a real .env for you.

# Server port
PORT=3001

# Admin token for protected endpoints (config changes, fan control, updates)
# REQUIRED in production: openssl rand -hex 16
ADMIN_TOKEN=

# CORS allowed origins (deploy.sh defaults this to your Pi's LAN address)
CORS_ORIGINS=*

# 64-hex-char key encrypting SMTP/NAS credentials at rest
# Generate: openssl rand -hex 32
SECRET_KEY=

# Shared secret authenticating the dashboard <-> host agent channel
# Generate: openssl rand -hex 32   (must match /etc/rapisys/agent.env)
AGENT_SECRET=

# Metrics sampling cadence in seconds
SAMPLE_INTERVAL_S=10
